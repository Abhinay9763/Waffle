# Render API base URL
TARGET_HOST=https://your-render-api.onrender.com

# Comma-separated exam IDs to distribute users acrossfast
EXAM_IDS=101,102,103,104,105

# Path to CSV credentials file
USERS_CSV=Server/loadtest/users.csv

# Headless run controls
LOADTEST_USERS=200
SPAWN_RATE=20
RUN_TIME=20m

# Heartbeat interval seconds
HEARTBEAT_SECONDS=30

# Send full snapshot every N heartbeats (otherwise delta)
FULL_SNAPSHOT_EVERY=3

# Start submitting after this many heartbeats
SUBMIT_AFTER_HEARTBEATS=8

# Optional: bootstrap users.csv via API (no direct DB edits)
BOOTSTRAP_USER_COUNT=200
BOOTSTRAP_PASSWORD=ChangeMe123!
BOOTSTRAP_START_INDEX=0
